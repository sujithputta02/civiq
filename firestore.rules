rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if user has admin role
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection - each user can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Admin can read user records ONLY when the user has given explicit consent
      // (GDPR/CCPA-aligned: Layer 14 – Privacy & Data Ethics)
      allow read: if isAdmin()
                  && resource.data.keys().hasAll(['electionData'])
                  && resource.data.electionData.keys().hasAll(['consentGiven'])
                  && resource.data.electionData.consentGiven == true;

      // Chat history - only owner can access
      match /chat/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Aggregates collection - read-only for authenticated users, write-only for backend
    match /aggregates/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend service account can write
    }

    // Admin collection - only admins can read
    match /admin/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only backend service account can write
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
