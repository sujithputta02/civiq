{
  "name": "civiq",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "concurrently -p \"[{name}]\" -n \"TURBO,LINKS\" -c \"cyan,magenta\" \"turbo dev\" \"sleep 5 && echo '\n🚀 Civiq Platform is ready!\n🌐 Web App: http://localhost:3000\n📡 API Service: http://localhost:3010\n🏥 API Health: http://localhost:3010/health\n'\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "test:coverage": "turbo test:coverage",
    "quality": "turbo typecheck lint test:run",
    "prepare": "husky install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "2.9.8",
    "typescript": "^5.0.0"
  }
}
